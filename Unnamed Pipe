#include <stdio.h>
#include <unistd.h>
#include <string.h>

int main()
{
    int fd[2];
    char buffer[100];

    pipe(fd);

    if(fork() == 0)
    {
        read(fd[0], buffer, sizeof(buffer));
        printf("Child Received: %s\n", buffer);
    }
    else
    {
        write(fd[1], "Hello Child", 12);
    }

    return 0;
}
